# --- Connection Helpers ---
def distance(origin, destination):
    lat1, lon1 = origin
    lat2, lon2 = destination
    radius = 6371  # km
    dlat = math.radians(lat2 - lat1)
    dlon = math.radians(lon2 - lon1)
    a = (math.sin(dlat / 2) ** 2 + math.cos(math.radians(lat1)) *
         math.cos(math.radians(lat2)) * math.sin(dlon / 2) ** 2)
    return radius * 2 * math.atan2(math.sqrt(a), math.sqrt(1 - a))


def build_user_agent():
    return 'Mozilla/5.0 (speedtest-cli/%s) Python/%s' % (__version__, platform.python_version())


def build_request(url, data=None, headers=None, secure=False):
    if not headers: headers = {}
    if url.startswith(':'):
        url = ('https' if secure else 'http') + url
    return Request(url, data=data, headers=headers)


def catch_request(request, opener=None):
    _open = opener.open if opener else urlopen
    try:
        uh = _open(request)
        return uh, False
    except Exception as e:
        return None, e


# --- Enhanced Downloader for Sustained Single Connection ---
class SustainedDownloader(threading.Thread):
    def __init__(self, request, timeout, opener=None, shutdown_event=None):
        threading.Thread.__init__(self)
        self.request = request
        self.timeout = timeout
        self.result = [0]
        self._opener = opener.open if opener else urlopen
        self._shutdown_event = shutdown_event or FakeShutdownEvent()

    def run(self):
        start_time = timeit.default_timer()
        try:
            f = self._opener(self.request)
            while not self._shutdown_event.is_set():
                if (timeit.default_timer() - start_time) >= self.timeout:
                    break
                chunk = f.read(65536)  # Larger chunks for high speed
                if not chunk:
                    break
                self.result.append(len(chunk))
            f.close()
        except Exception:
            pass


class SustainedUploader(threading.Thread):
    def __init__(self, url, timeout, opener=None, shutdown_event=None):
        threading.Thread.__init__(self)
        self.url = url
        self.timeout = timeout
        self.result = 0
        self.total_sent = [0]
        self._opener = opener.open if opener else urlopen
        self._shutdown_event = shutdown_event or FakeShutdownEvent()

    def run(self):
        start_time = timeit.default_timer()
        # Create a large data block to reuse
        data_block = b'0' * 1048576  # 1MB block
        try:
            while not self._shutdown_event.is_set():
                if (timeit.default_timer() - start_time) >= self.timeout:
                    break
                # Perform a sustained POST
                req = build_request(self.url, data=data_block)
                f = self._opener(req)
                f.read(11)
                f.close()
                self.total_sent.append(len(data_block))
            self.result = sum(self.total_sent)
        except Exception:
            self.result = sum(self.total_sent)


# --- Main Speedtest Class ---
class Speedtest(object):
    def __init__(self, source_address=None, timeout=10, secure=False):
        self.config = {}
        self.servers = {}
        self._secure = secure
        self._timeout = timeout
        self._opener = build_opener()
        self.get_config()
        self.results = SpeedtestResults(client=self.config['client'], secure=secure)

    def get_config(self):
        req = build_request('://www.speedtest.net/speedtest-config.php', secure=self._secure)
        uh, e = catch_request(req, opener=self._opener)
        if e: raise ConfigRetrievalError(e)
        configxml = uh.read()
        root = ET.fromstring(configxml)
        self.config = {
            'client': root.find('client').attrib,
            'length': {'download': 20, 'upload': 20}  # Default to 20 seconds
        }
        self.lat_lon = (float(self.config['client']['lat']), float(self.config['client']['lon']))
        return self.config

    def get_servers(self, servers=None):
        url = 'https://gist.githubusercontent.com/stas-sl/eecfbf3ba2497d1171dcb28cc0fb73ee/raw/'
        req = build_request(url, secure=self._secure)
        uh, e = catch_request(req, opener=self._opener)
        if e: raise ServersRetrievalError()

        csv_data = uh.read().decode('utf-8')
        reader = csv.reader(csv_data.splitlines())
        next(reader, None)

        all_servers = []
        for row in reader:
            if not row or len(row) < 10 or row[0].lower() == 'id': continue
            all_servers.append({
                'id': row[0].strip(), 'url': row[1].strip(), 'lat': row[2].strip(),
                'lon': row[3].strip(), 'name': row[4].strip(), 'country': row[5].strip(),
                'sponsor': row[7].strip(), 'host': row[9].strip(), 'd': 0
            })

        chosen = None
        if servers:
            target = str(servers[0])
            chosen = next((s for s in all_servers if s['id'] == target), None)

        if not chosen:
            print_("\nEnter country name to filter: ", end="")
            country = sys.stdin.readline().strip().lower()
            matched = [s for s in all_servers if country in s['country'].lower()]
            if not matched:
                print_("No servers found.");
                sys.exit(1)
            for s in matched:
                print_("ID: %s | City: %s | ISP: %s" % (s['id'], s['name'], s['sponsor']))
            print_("\nEnter Server ID: ", end="")
            cid = sys.stdin.readline().strip()
            chosen = next((s for s in matched if s['id'] == cid), None)
            if not chosen: print_("Invalid ID."); sys.exit(1)

        dist = distance(self.lat_lon, (float(chosen['lat']), float(chosen['lon'])))
        chosen['d'] = dist
        self.servers = {dist: [chosen]}
        self._best = chosen
        return self.servers

    def get_best_server(self):
        # Already set during get_servers in this modified version
        self.results.server = self._best
        return self._best

    def download(self):
        # Use the largest available file for a sustained stream
        url = os.path.dirname(self._best['url']) + '/random4000x4000.jpg'
        thread = SustainedDownloader(build_request(url), self.config['length']['download'], self._opener)
        start = timeit.default_timer()
        thread.start()
        thread.join()
        stop = timeit.default_timer()
        self.results.bytes_received = sum(thread.result)
        self.results.download = (self.results.bytes_received / (stop - start)) * 8.0
        return self.results.download

    def upload(self):
        thread = SustainedUploader(self._best['url'], self.config['length']['upload'], self._opener)
        start = timeit.default_timer()
        thread.start()
        thread.join()
        stop = timeit.default_timer()
        self.results.bytes_sent = thread.result
        self.results.upload = (self.results.bytes_sent / (stop - start)) * 8.0
        return self.results.upload

    def start_mtr(self):
        host = self._best['host'].split(':')[0]
        print_('Starting MTR to %s...' % host)
        try:
            self._mtr_process = subprocess.Popen(['mtr', '-r', '-c', '5', '-z', host],
                                                 stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        except:
            self._mtr_process = None

    def get_mtr_report(self):
        if not getattr(self, '_mtr_process', None): return "MTR failed."
        out, _ = self._mtr_process.communicate()
        return out.decode('utf-8', 'ignore')


class SpeedtestResults(object):
    def __init__(self, download=0, upload=0, ping=0, server=None, client=None, secure=False):
        self.download, self.upload, self.ping = download, upload, ping
        self.server = server or {}
        self.client = client or {}
        self.timestamp = datetime.datetime.utcnow().isoformat() + 'Z'
        self.bytes_received = self.bytes_sent = 0

    def dict(self):
        return {'download': self.download, 'upload': self.upload, 'server': self.server, 'client': self.client}


def build_opener():
    opener = OpenerDirector()
    for handler in [ProxyHandler(), HTTPDefaultErrorHandler(), HTTPRedirectHandler(), HTTPErrorProcessor()]:
        opener.add_handler(handler)
    opener.addheaders = [('User-agent', build_user_agent())]
    return opener


def shell():
    parser = ArgParser()
    parser.add_argument('--server', type=int, action='append')
    parser.add_argument('--secure', action='store_true')
    args = parser.parse_args()

    print_('Retrieving configuration...')
    st = Speedtest(secure=args.secure)
    st.get_servers(servers=args.server)
    st.get_best_server()

    st.start_mtr()
    res = st.results
    print_('Hosted by %s [%.2f km]: City: %s' % (res.server['sponsor'], res.server['d'], res.server['name']))

    print_('Testing download speed (20s sustained)...')
    st.download()
    print_('Download: %.2f Mbit/s' % (res.download / 1e6))

    print_('Testing upload speed (20s sustained)...')
    st.upload()
    print_('Upload: %.2f Mbit/s' % (res.upload / 1e6))

    print_('\nWaiting for MTR report...')
    print_('--- MTR Report ---\n%s' % st.get_mtr_report())


if __name__ == '__main__':
    shell()