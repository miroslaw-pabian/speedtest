# Helper for UTF-8 printing
def print_(*args, **kwargs):
    fp = kwargs.pop("file", sys.stdout)
    if fp is None: return
    data = " ".join([str(x) for x in args])
    fp.write(data + kwargs.pop("end", "\n"))
    fp.flush()


